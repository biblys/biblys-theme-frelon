{% extends "layout:base.html.twig" %}

{% block main %}
  {#
  CAROUSEL
  Pour changer le contenu du carousel,
  modifier le code ci-dessous
  #}

  <div id="HomeCarousel" class="carousel slide" data-ride="carousel" data-interval="5000">

    {# Indicateurs #}

    <ol class="carousel-indicators mb-0">
      <li data-target="#HomeCarousel" data-slide-to="0" class="active"></li>
      <li data-target="#HomeCarousel" data-slide-to="1" "></li>
      <li data-target="#HomeCarousel" data-slide-to="2" "></li>
      <li data-target="#HomeCarousel" data-slide-to="3" "></li>
      <li data-target="#HomeCarousel" data-slide-to="4"></li>
      <li data-target="#HomeCarousel" data-slide-to="5" "></li>
    </ol>

    <div class="carousel-inner">
        
        
        	
        	{# Bannière 1 #}
      <div class="carousel-item active">
        <a href="/a/nathalie-garnaud/les-cahiers-de-madame-durosier"
           target="_blank">
          <img
            class="carousel-image"
            src="https://lebaiserdufrelon.fr/media/carousel/lautre-livre-visuel-1920x559.jpg"
            alt="Le salon international de l'édition indépendante du 1er au 3 mai. Halle des Blanc-Manteaux, Paris 4e" 
            width="1024"
            height="300"
          />
        </a>
      </div>
        
      {# Bannière 21 #}
      <div class="carousel-item">
        <a href="/a/nathalie-garnaud/les-cahiers-de-madame-durosier"
           target="_blank">
          <img
            class="carousel-image"
            src="https://lebaiserdufrelon.fr/media/carousel/durosier-1024x300.jpg"
            alt="Les Cahiers de Madame Durosier" 
            width="1024"
            height="300"
          />
        </a>
      </div>
      
        {# Bannière 3 #}
        <div class="carousel-item">
        <a href="/a/charles-fantin/meditation-sur-la-langue-et-le-pouvoir"
           target="_blank">
          <img
            class="carousel-image"
            src="https://lebaiserdufrelon.fr/media/carousel/charles02-1024x300.jpg"
            alt="Méditation sur la langue et le pouvoir de Charles Fantin. Tome 2. La Chute" 
            width="1024"
            height="300"
          />
        </a>
      </div>
        
        {# Bannière 4 #}
         <div class="carousel-item">
        <a href="/a/charles-fantin/meditation-sur-la-langue-et-le-pouvoir-tome-1"
           target="_blank">
          <img
            class="carousel-image"
            src="https://lebaiserdufrelon.fr/media/carousel/charles01-1024x300.jpg"
            alt="Méditation sur la langue et le pouvoir de Charles Fantin"
            width="1024"
            height="300"
          />
        </a>
      </div>

      {# Bannière 5 #}
      <div class="carousel-item">
        <a href="/a/oderic-delefosse/raconter-rediger-lire-a-tout-age">
          <img
            class="carousel-image"
            src="https://lebaiserdufrelon.fr/media/carousel/oderic-1024x300.jpg"
            alt="Toutes les langues sont porteuses de richesse humaine, de poésie, de connaissances, d'expérience et de valeurs de civilisation, chacune apportant sa note originale
dans l'intelligence du monde et de la vie. Extrait du livre Raconter, rédiger, lire à tout âge d'Odéric Delefosse"
            width="1024"
            height="300"
          />
        </a>
      </div>
      
             {# Bannière 6 #}
       <div class="carousel-item">
        <a href="/a/cecile-blow/boostez-votre-vitalite">
          <img
            class="carousel-image"
            src="https://lebaiserdufrelon.fr/media/carousel/cecile-1024x300.jpg"
            alt="Boostez votre vitalité.Guide pratique pour faire face aux ruptures, divorce, burn-out… de Cecile Blow"
            width="1024"
            height="300"
          />
        </a>
      </div>
      
     

    </div>

    <div class="swiper-pagination"></div>
  </div>

  <section class="home-page-articles">
    {% for article in articles %}
      <div class="home-page-article">
        {% if article.model|hasImage %}
          <a
            href="{{ path('article_show', {slug: article.url}) }}"
            class="home-page-article__cover"
          >
            <img
              src="{{ article.model|imageUrl }}"
              alt="{{ article.title }}"
              class="home-page-article__cover-image"
            />
          </a>
        {% endif %}
        <div class="home-page-article__infos">
          {% if article.model.cycle %}
            <p class="home-page-article__cycle">
              <a href="{{ path('cycle_show', {slug: article.model.cycle.url}) }}">
                {{ article.model.cycle.name }}
              </a>
              {% if article.has('tome') %}
                · tome {{ article.tome }}
              {% endif %}
            </p>
          {% endif %}
          <h1 class="home-page-article__title">
            <a href="{{ path('article_show', {slug: article.url}) }}">
              {{ article.title }}
            </a>
          </h1>
          <p class="home-page-article__authors">
            {{ article.authors|authors }}
          </p>
          {% if article.has('catchline') %}
            <div class="home-page-article__catchline">
              {{ article.catchline|raw }}
            </div>
          {% endif %}

          {% if article.has('bonus') %}
            <div class="home-page-article__bonus">
              {{ article.bonus|raw }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </section>
{% endblock %}
